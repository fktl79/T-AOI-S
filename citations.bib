@inproceedings{wang_research_2023,
 abstract = {Aircraft Glass Canopy (AGC) is an important part of human-aircraft interface, and efficient and real-time AGC surface defect detection has become a prerequisite for pilots to perceive the external field of vision normally. While existing deep learning models are sufficient for routine defect detection, AGC surface defects are characterized by tiny and high aspect ratios, which make accurate defect detection challenging. Therefore, this paper proposes an improved YOLOv4 rotating target detection model. Specifically, we firstly employs the decoupled head to improve the model performance and convergence efficiency on the basis of the original YOLOv4 model. Secondly, we construct a multi-dimensional coordinate structure for high aspect ratio defects, and achieve rotation detection by optimizing the loss function. Finally, we utilize Fuzzy C-means (FCM) to cluster AGC surface defects to obtain the most suitable initial anchor box size. Experimental results show that the mAP value is improved by 6.16\% compared to the original YOLOv4 model, which proves the effectiveness of our proposed model.},
 address = {New York, NY, USA},
 author = {Wang, Jing and Wang, Kexin and Li, Jianhong},
 booktitle = {Proceedings of the 2022 5th {International} {Conference} on {Machine} {Learning} and {Machine} {Intelligence}},
