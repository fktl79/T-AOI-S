@article{MING2020107722,
title = {A comprehensive review of defect detection in 3C glass components},
journal = {Measurement},
volume = {158},
pages = {107722},
year = {2020},
issn = {0263-2241},
doi = {https://doi.org/10.1016/j.measurement.2020.107722},
url = {https://www.sciencedirect.com/science/article/pii/S0263224120302608},
author = {Wuyi Ming and Fan Shen and Xiaoke Li and Zhen Zhang and Jinguang Du and Zhijun Chen and Yang Cao},
keywords = {Defect detection, Image preprocessing, Image segmentation, Feature extraction, Classifier, Machine vision, 3C glass components},
abstract = {With the development of consumer electronics industry, it is inevitable for the industry to use machine vision instead of manual inspection. In this paper, the defect detection of 3C glass components is summarized according to the actual production process. The defects of glass components are classified in details for the first time. The causes of these defects and the optical characteristics exhibited in the detection process are also analyzed. Because the detection effect is determined by classifier, the performance of various classifiers is discussed in details under the same criterion. On the whole, the neural network classifier is obviously better than the traditional methods, and the unsupervised classifier is better than the supervised one. The current detection accuracy is about 90%, and the computational complexity of high-accuracy classifiers is large. In the future, the improvement of accuracy and the reduction of computational complexity are still the research focus.}
}

