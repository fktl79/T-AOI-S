 isbn = {978-1-4503-9755-1},
 keywords = {defect detection, Aircraft Glass Canopy, FCM, rotation detection, YOLOv4},
 pages = {140--145},
 publisher = {Association for Computing Machinery},
 series = {{MLMI} '22},
 title = {Research on {Rotation} {Detection} of {Aircraft} {Glass} {Canopy} {Defects} {Based} on {Deep} {Learning}},
 url = {https://doi.org/10.1145/3568199.3568221},
 year = {2023}
}

@inproceedings{wang_surface_2023,
 abstract = {With the development of science and technology, transparent parts are almost used in various industries and play an indispensable role. It is meaningful to measure the surface quality of transparent parts. To improve the detection accuracy of surface defects on transparent parts, an improved YOLOv4 target detection model is proposed in this paper. Firstly, to expand the amount of dataset, we adopt Mosaic strategy combined with Copy-Pasting strategy for data augmentation. Secondly, the Canopy + K-means clustering algorithm is employed to select the initial anchor box size. Finally, to improve the feature representation ability of the model, Squeeze-and-Excitation Networks (SENet) with an attention mechanism is embedded to the model. Experiments show that the mAP value of the improved YOLOv4 model on the test set reaches 91.07\%, which is 6.4\% higher than that of Faster R-CNN and 4.15\% higher than that of the original YOLOv4 model, which proves the effectiveness of our model.},
 address = {New York, NY, USA},
 author = {Wang, Jing and Li, Jianhong and Wei, Siwen},
 booktitle = {Proceedings of the 2022 5th {International} {Conference} on {Machine} {Learning} and {Machine} {Intelligence}},
