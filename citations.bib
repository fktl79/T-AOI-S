@article{zhang_novel_2025,
 abstract = {In industrial processes, detecting surface defects is crucial for enhancing product quality and production efficiency. However, detecting defects at smaller scales remains challenging. A new end-to-end multi-scale surface defect detection method, termed as context-adaptive multi-scale defect detection (CAMDD), is proposed to address this issue. Firstly, a novel feature pyramid network, named the context and texture-extractor module with feature pyramid network (CTM-FPN), is introduced, incorporating a context extractor, texture extractor, and multi-scale residual atrous spatial pyramid pooling (MR-ASPP) to enhance the representation capability of defect features at different scales. Secondly, an adaptive threshold soft non-maximum suppression (ATS-NMS) post-processing algorithm is proposed to address the issue of interweaving defects of different scales, which may incorrectly suppress information about small defects, thereby reducing the model's false negative rate. By integrating the two modules mentioned above into existing object detection methods, the CAMDD method is formed. Experimental results on two steel plate datasets and a dataset of tiny transparent lenses demonstrate that the proposed CAMDD method has advantages in accuracy for detecting defects of various scales.},
 author = {Zhang, Hongbin and Liu, Jianhua and Pan, Dong and Jiang, Zhaohui and Dong, Jinzong},
 doi = {10.1016/j.neucom.2025.130927},
 issn = {0925-2312},
 journal = {NEUROCOMPUTING},
 keywords = {Deep learning, Surface defect detection, Convolutional neural network, Multi-scale defects},
 language = {English},
 month = {October},
 note = {Place: RADARWEG 29, 1043 NX AMSTERDAM, NETHERLANDS
Type: Article},
 publisher = {ELSEVIER},
 title = {A novel context-adaptive multi-scale defect detection method for object surface defects},
 volume = {650},
 year = {2025}
}

